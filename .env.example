# ─────────────────────────────────────────────────────────────
# AGJ Cinema — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.
# ─────────────────────────────────────────────────────────────

# ── TMDB API ────────────────────────────────────────────────
# Get your key from: https://www.themoviedb.org/settings/api
VITE_TMDB_API_KEY=your_tmdb_api_key_here

# ── Vercel Edge Function (server-side, same key) ────────────
# Add this in Vercel Dashboard → Settings → Environment Variables
TMDB_API_KEY=your_tmdb_api_key_here

# ── Streaming Player ────────────────────────────────────────
# Base URL for the embed player (must end with /movie/ or similar)
VITE_STREAM_BASE_URL=https://vidsrc.xyz/embed/movie/

# Player accent color (hex value without the # symbol)
VITE_STREAM_PRIMARY_COLOR=06b6d4

# Default subtitle/audio language code (en, ar, fr, etc.)
VITE_STREAM_DEFAULT_LANG=en
